<!-- ═══════════ SCRIPT ═══════════ -->
<script>
  /* ── Package Selection ── */
  let pkgPrice = 18500000;
  let addonTotal = 0;
  const pkgNames = {
    silver:   'Intimate (Silver)',
    gold:     'Luminous (Gold)',
    platinum: 'Grand Luminara (Platinum)'
  };
  const pkgPrices = { silver: 8500000, gold: 18500000, platinum: 35000000 };

  function selectPackage(id, price) {
    ['silver','gold','platinum'].forEach(p => {
      document.getElementById('pkg-'+p).classList.remove('selected');
    });
    document.getElementById('pkg-'+id).classList.add('selected');
    pkgPrice = price;
    document.getElementById('sum-package').textContent = pkgNames[id];
    updateSummary();
  }

  /* ── Add-on Toggle ── */
  function toggleAddon(el, price) {
    el.classList.toggle('checked');
    if (el.classList.contains('checked')) {
      addonTotal += price;
    } else {
      addonTotal -= price;
    }
    updateSummary();
  }

  /* ── Summary Update ── */
  function fmt(n) {
    return 'Rp ' + n.toLocaleString('id-ID');
  }

  function updateSummary() {
    const total = pkgPrice + addonTotal;
    const dp = Math.round(total * 0.3);
    document.getElementById('sum-pkg-price').textContent = fmt(pkgPrice);
    document.getElementById('sum-addons').textContent = fmt(addonTotal);
    document.getElementById('sum-dp').textContent = fmt(dp);
    document.getElementById('sum-total').textContent = fmt(total);
  }

  /* ── Form Submit ── */
  function handleSubmit(e) {
    e.preventDefault();
    const required = ['groomName','brideName','phone','email','akadDate','resepsiDate','guests','city'];
    let valid = true;
    required.forEach(id => {
      const el = document.getElementById(id);
      if (!el.value.trim()) {
        el.style.borderColor = '#c0392b';
        valid = false;
      } else {
        el.style.borderColor = '';
      }
    });
    if (!valid) {
      alert('Mohon lengkapi semua field yang wajib diisi (ditandai *).');
      return;
    }
    // Success mock
    const overlay = document.createElement('div');
    overlay.style.cssText = `position:fixed;inset:0;background:rgba(47,73,54,0.92);display:flex;align-items:center;justify-content:center;z-index:999;animation:fadeUp .4s ease`;
    overlay.innerHTML = `
      <div style="background:#f2f0e4;padding:48px 56px;text-align:center;max-width:480px;border:1px solid #c9a84c;">
        <div style="font-size:2.5rem;margin-bottom:18px;">✦</div>
        <h2 style="font-family:'Cinzel',serif;color:#2f4936;font-size:1.4rem;letter-spacing:.1em;margin-bottom:12px;">Pemesanan Terkirim!</h2>
        <p style="font-family:'Montserrat',sans-serif;font-size:.78rem;color:#9a8d7b;line-height:1.8;margin-bottom:28px;">
          Terima kasih telah mempercayakan hari istimewa Anda kepada <strong>Luminara Wedding Organizer</strong>.<br/>
          Tim kami akan menghubungi Anda dalam 1×24 jam untuk konfirmasi.
        </p>
        <button onclick="this.parentElement.parentElement.remove()" style="font-family:'Cinzel',serif;font-size:.78rem;letter-spacing:.25em;color:#2f4936;background:linear-gradient(135deg,#e8d08a,#c9a84c);border:none;padding:14px 40px;cursor:pointer;">Tutup ✦</button>
      </div>
    `;
    document.body.appendChild(overlay);
  }

  function resetForm() {
    selectPackage('gold', 18500000);
    addonTotal = 0;
    document.querySelectorAll('.addon-item').forEach(el => el.classList.remove('checked'));
    updateSummary();
  }

  // Init
  updateSummary();

  // Mobile drawer
  function toggleDrawer() {
    document.getElementById('navDrawer').classList.toggle('open');
  }
</script>
